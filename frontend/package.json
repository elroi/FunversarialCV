{
    "name": "funversarial-cv",
    "version": "1.0.0",
    "private": true,
    "description": "Adversarial CV egg-injection tool for security professionals.",
    "scripts": {
        "dev": "NODE_OPTIONS='--no-deprecation' next dev",
        "build": "next build",
        "start": "NODE_OPTIONS='--no-deprecation' next start",
        "lint": "next lint",
        "test": "jest",
        "test:manual-list": "jest app/page.test.tsx --testNamePattern=\"Manual test list\"",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "gen:e2e-fixtures": "node scripts/gen-e2e-fixtures.mjs",
        "gen:jd-baseline": "node scripts/gen-jd-baseline.mjs",
        "gen:research-fixtures": "tsx scripts/gen-research-docx-fixtures.ts",
        "check:research-pdf": "node scripts/check-research-pdf-eggs.mjs",
        "gen:demo-cv": "node scripts/gen-demo-cv-once.mjs",
        "postinstall": "node -e \"const fs=require('fs');const p=require('path');const src=p.join('node_modules','pdfjs-dist','build','pdf.worker.min.mjs');const dest=p.join('public','pdf.worker.min.mjs');if(fs.existsSync(src)){fs.mkdirSync('public',{recursive:true});fs.copyFileSync(src,dest);console.log('Copied pdf.worker.min.mjs to public/');}\""
    },
    "dependencies": {
        "@embedpdf/pdfium": "^2.8.0",
        "@vercel/analytics": "^2.0.1",
        "clsx": "^2.1.0",
        "docx": "^8.5.0",
        "jszip": "^3.10.1",
        "lucide-react": "^0.330.0",
        "mammoth": "^1.12.0",
        "next": "14.1.0",
        "pako": "^1.0.11",
        "pdf-lib": "^1.17.1",
        "pdf-parse": "^1.1.1",
        "pdfjs-dist": "^5.3.93",
        "react": "^18",
        "react-dom": "^18",
        "tailwind-merge": "^2.2.1",
        "word-extractor": "^1.0.4",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.0.0",
        "@types/jest": "^29",
        "@types/node": "^20",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "autoprefixer": "^10.0.1",
        "bs-logger": "^0.2.6",
        "call-bound": "^1.0.4",
        "eslint": "8.57.0",
        "eslint-config-next": "14.1.0",
        "jest": "^29",
        "jest-environment-jsdom": "^30.2.0",
        "postcss": "^8",
        "tailwindcss": "^3.3.0",
        "ts-jest": "^29",
        "tsx": "^4.19.4",
        "typescript": "^5"
    }
}
